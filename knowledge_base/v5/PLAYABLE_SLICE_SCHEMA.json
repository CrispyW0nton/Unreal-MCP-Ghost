{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Unreal MCP Playable Slice Plan",
  "type": "object",
  "required": ["schema", "brief", "theme", "content_path", "requested_asset_roles", "assets", "gameplay", "tool_sequence", "validation"],
  "properties": {
    "schema": {
      "const": "unreal_mcp_playable_slice_plan.v1"
    },
    "brief": {
      "type": "string",
      "minLength": 1
    },
    "theme": {
      "type": "string",
      "minLength": 1
    },
    "content_path": {
      "type": "string",
      "pattern": "^/Game"
    },
    "assets": {
      "type": "array",
      "minItems": 4,
      "maxItems": 4,
      "items": {
        "type": "object",
        "required": ["role", "description", "name", "prompt", "provider", "task_type", "content_path", "smart_low_poly"],
        "properties": {
          "role": {
            "enum": ["hero", "prop", "enemy"]
          },
          "description": {
            "type": "string",
            "minLength": 1
          },
          "name": {
            "type": "string",
            "minLength": 1
          },
          "prompt": {
            "type": "string",
            "minLength": 1
          },
          "provider": {
            "type": "string"
          },
          "task_type": {
            "type": "string"
          },
          "content_path": {
            "type": "string",
            "pattern": "^/Game"
          },
          "smart_low_poly": {
            "const": true
          }
        }
      }
    },
    "requested_asset_roles": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "gameplay": {
      "type": "object",
      "required": ["player_blueprint", "enemy_blueprint", "behavior_tree", "blackboard", "hud_widget", "requested_loop", "level_goal"]
    },
    "tool_sequence": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["phase", "tools"]
      }
    },
    "validation": {
      "type": "object",
      "required": ["required_blueprints", "acceptance_criteria", "required_runtime_evidence", "report_tool"]
    }
  }
}
